# Server
PORT=3000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=github_analyzer
DB_CONNECTION_LIMIT=10

# GitHub API
# Optional but strongly recommended: create a Personal Access Token (no scopes needed
# for public data) to raise the rate limit from 60/hr to 5000/hr.
# https://github.com/settings/tokens
GITHUB_TOKEN=

# API key required for write operations (POST/DELETE on /api/profiles).
# Generate any random string, e.g.: openssl rand -hex 32
# Leave blank for local dev only — IMPORTANT: set this before deploying publicly,
# or anyone with your URL can trigger analyses (burning your GitHub quota) or delete data.
API_KEY=

# Rate limiting (requests per window, per IP) for our own API
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
